# Base de Datos (dentro de Docker, usar el nombre del servicio)
DATABASE_URL=postgres://admin:adminpassword@postgres:5432/sistema_valvulas

# MinIO (S3-compatible storage)
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=admin_minio
MINIO_SECRET_KEY=password_minio
MINIO_BUCKET=valsys

# Meilisearch (full-text search)
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=masterKey123!

# Auth
JWT_SECRET=<generate-a-secure-random-string>

# Next.js
HOSTNAME=0.0.0.0
PORT=3000
NODE_ENV=production

# Cloudflare Tunnel (obtené el token en one.dash.cloudflare.com > Networks > Tunnels)
CLOUDFLARE_TUNNEL_TOKEN=<pegar-token-aqui>
